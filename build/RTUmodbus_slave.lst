 157:modbus/RTUmodbus_slave.c **** static void MODS_SendWithCRC(uint8_t *_pBuf, uint8_t _ucLen)
 158:modbus/RTUmodbus_slave.c **** {
 159:modbus/RTUmodbus_slave.c **** 	uint16_t crc;
 160:modbus/RTUmodbus_slave.c **** 	uint8_t buf[S_TX_BUF_SIZE];
