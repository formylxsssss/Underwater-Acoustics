 162:modbus/RTUmodbus_slave.c **** 	memcpy(buf, _pBuf, _ucLen);
 163:modbus/RTUmodbus_slave.c **** 	crc = CRC16_Modbus(_pBuf, _ucLen);
 164:modbus/RTUmodbus_slave.c **** 	buf[_ucLen++] = crc >> 8;
 165:modbus/RTUmodbus_slave.c **** 	buf[_ucLen++] = crc;
 166:modbus/RTUmodbus_slave.c **** 	#warning У┐ЎжЄїжюђУдЂу╗ЎтЄ║СИђСИфтЈЉжђЂуџёТјЦтЈБ
