 164:modbus/RTUmodbus_slave.c **** static void MODS_SendWithCRC(uint8_t *_pBuf, uint8_t _ucLen)
 165:modbus/RTUmodbus_slave.c **** {
 166:modbus/RTUmodbus_slave.c **** 	uint16_t crc;
 167:modbus/RTUmodbus_slave.c **** 	uint8_t buf[S_TX_BUF_SIZE];
