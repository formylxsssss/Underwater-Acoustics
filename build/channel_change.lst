   8:diff_signal/channel_change.c **** /*
   9:diff_signal/channel_change.c ****  * 说明：
  10:diff_signal/channel_change.c ****  * 1. 保持原有接口名字不变
  11:diff_signal/channel_change.c ****  * 2. 去掉 HAL_Delay(1)，避免 ms 级阻塞影响 100bps 发送节拍
  12:diff_signal/channel_change.c ****  * 3. 对 74HCT257 这类逻辑器件，本体切换是 ns 级，不需要 1ms 等待
  13:diff_signal/channel_change.c ****  * 4. 如果你后级模拟链路确实需要更长建立时间，后续再单独加
  14:diff_signal/channel_change.c ****  */
  15:diff_signal/channel_change.c **** 
  16:diff_signal/channel_change.c **** /* 很短的保护延时，避免GPIO连续翻转过快。
  17:diff_signal/channel_change.c ****    这里只做几个 NOP，不再用 HAL_Delay 或 DWT。 */
  18:diff_signal/channel_change.c **** static inline void channel_short_delay(void)
  19:diff_signal/channel_change.c **** {
  20:diff_signal/channel_change.c ****     __NOP();
  21:diff_signal/channel_change.c ****     __NOP();
  22:diff_signal/channel_change.c ****     __NOP();
  23:diff_signal/channel_change.c ****     __NOP();
  24:diff_signal/channel_change.c ****     __NOP();
  25:diff_signal/channel_change.c ****     __NOP();
  26:diff_signal/channel_change.c ****     __NOP();
  27:diff_signal/channel_change.c ****     __NOP();
  28:diff_signal/channel_change.c **** }
  29:diff_signal/channel_change.c **** 
  30:diff_signal/channel_change.c **** /* 通用 74HCT257 切换函数
  31:diff_signal/channel_change.c ****    /OE 低有效：
  32:diff_signal/channel_change.c ****    - GPIO_PIN_SET   -> 禁止输出（高阻）
ARM GAS  /tmp/ccnJVm93.s 			page 2


  33:diff_signal/channel_change.c ****    - GPIO_PIN_RESET -> 使能输出
  34:diff_signal/channel_change.c **** 
  35:diff_signal/channel_change.c ****    S 选择端：
  36:diff_signal/channel_change.c ****    - GPIO_PIN_RESET -> 选 A
  37:diff_signal/channel_change.c ****    - GPIO_PIN_SET   -> 选 B
  38:diff_signal/channel_change.c **** */
