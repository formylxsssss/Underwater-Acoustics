  54:sensor_device/DHT22.c **** /**
  55:sensor_device/DHT22.c ****  * @brief  检测传感器应答信号
  56:sensor_device/DHT22.c ****  * @return 1 = 有响应，0 = 无响应
  57:sensor_device/DHT22.c ****  */
  58:sensor_device/DHT22.c **** static uint8_t DHT22_CheckResponse(void)
  59:sensor_device/DHT22.c **** {
  60:sensor_device/DHT22.c ****     uint32_t t = 0;
  61:sensor_device/DHT22.c ****     // 等待拉低（≈80us）
  62:sensor_device/DHT22.c ****     while (HAL_GPIO_ReadPin(DHT22_GPIO_Port, DHT22_Pin) == GPIO_PIN_SET)
  63:sensor_device/DHT22.c ****     {
  64:sensor_device/DHT22.c ****         if (++t > 100) return 0;
  65:sensor_device/DHT22.c ****         Delay_us(1);
  66:sensor_device/DHT22.c ****     }
  67:sensor_device/DHT22.c ****     t = 0;
  68:sensor_device/DHT22.c ****     // 等待拉高（≈80us）
  69:sensor_device/DHT22.c ****     while (HAL_GPIO_ReadPin(DHT22_GPIO_Port, DHT22_Pin) == GPIO_PIN_RESET)
  70:sensor_device/DHT22.c ****     {
