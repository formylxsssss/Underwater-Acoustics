  72:sensor_device/DHT22.c ****         Delay_us(1);
  73:sensor_device/DHT22.c ****     }
  74:sensor_device/DHT22.c ****     myprintf("tsssss is %d\n",t);
  75:sensor_device/DHT22.c ****     return 1;
