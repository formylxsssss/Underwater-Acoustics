  12:sensor_device/DHT22.c **** {
  13:sensor_device/DHT22.c ****     uint8_t data[5] = {0};
  14:sensor_device/DHT22.c **** 
  15:sensor_device/DHT22.c ****     // 启动信号 - 拉低18ms
  16:sensor_device/DHT22.c ****     DHT22_SetOutput();
  17:sensor_device/DHT22.c ****     HAL_GPIO_WritePin(DHT22_PIN_PORT, DHT22_PIN, GPIO_PIN_RESET);
  18:sensor_device/DHT22.c ****     HAL_Delay(18);
  19:sensor_device/DHT22.c **** 
  20:sensor_device/DHT22.c ****     // 拉高延时30µs
  21:sensor_device/DHT22.c ****     HAL_GPIO_WritePin(DHT22_PIN_PORT, DHT22_PIN, GPIO_PIN_SET);
  22:sensor_device/DHT22.c ****     DWT_Delay_us(30);
  23:sensor_device/DHT22.c **** 
  24:sensor_device/DHT22.c ****     // 切换为输入，准备接收响应
  25:sensor_device/DHT22.c ****     DHT22_SetInput();
  26:sensor_device/DHT22.c **** 
  27:sensor_device/DHT22.c ****     // 等待DHT22响应（低电平80us）
  28:sensor_device/DHT22.c ****     uint32_t timeout = 0;
  29:sensor_device/DHT22.c ****     while (HAL_GPIO_ReadPin(DHT22_PIN_PORT, DHT22_PIN)) {
  30:sensor_device/DHT22.c ****         if (++timeout > 100) return 1;
  31:sensor_device/DHT22.c ****         DWT_Delay_us(1);
  32:sensor_device/DHT22.c ****     }
ARM GAS  /tmp/ccnlI2Px.s 			page 2


  33:sensor_device/DHT22.c **** 
  34:sensor_device/DHT22.c ****     // 等待响应结束
  35:sensor_device/DHT22.c ****     timeout = 0;
  36:sensor_device/DHT22.c ****     while (!HAL_GPIO_ReadPin(DHT22_PIN_PORT, DHT22_PIN)) {
  37:sensor_device/DHT22.c ****         if (++timeout > 100) return 2;
  38:sensor_device/DHT22.c ****         DWT_Delay_us(1);
  39:sensor_device/DHT22.c ****     }
  40:sensor_device/DHT22.c **** 
  41:sensor_device/DHT22.c ****     timeout = 0;
  42:sensor_device/DHT22.c ****     while (HAL_GPIO_ReadPin(DHT22_PIN_PORT, DHT22_PIN)) {
  43:sensor_device/DHT22.c ****         if (++timeout > 100) return 3;
  44:sensor_device/DHT22.c ****         DWT_Delay_us(1);
  45:sensor_device/DHT22.c ****     }
  46:sensor_device/DHT22.c **** 
  47:sensor_device/DHT22.c ****     // 接收 40 位数据
  48:sensor_device/DHT22.c ****     for (int i = 0; i < 40; i++) {
  49:sensor_device/DHT22.c ****         // 等待开始位（低电平）
  50:sensor_device/DHT22.c ****         timeout = 0;
  51:sensor_device/DHT22.c ****         while (!HAL_GPIO_ReadPin(DHT22_PIN_PORT, DHT22_PIN)) {
  52:sensor_device/DHT22.c ****             if (++timeout > 100) return 4;
  53:sensor_device/DHT22.c ****             DWT_Delay_us(1);
  54:sensor_device/DHT22.c ****         }
  55:sensor_device/DHT22.c **** 
  56:sensor_device/DHT22.c ****         // 等待高电平并延迟 ~40µs 进行采样
  57:sensor_device/DHT22.c ****         DWT_Delay_us(40);
  58:sensor_device/DHT22.c ****         if (HAL_GPIO_ReadPin(DHT22_PIN_PORT, DHT22_PIN)) {
  59:sensor_device/DHT22.c ****             data[i / 8] |= (1 << (7 - (i % 8)));
  60:sensor_device/DHT22.c ****         }
  61:sensor_device/DHT22.c **** 
  62:sensor_device/DHT22.c ****         // 等待高电平结束
  63:sensor_device/DHT22.c ****         timeout = 0;
  64:sensor_device/DHT22.c ****         while (HAL_GPIO_ReadPin(DHT22_PIN_PORT, DHT22_PIN)) {
  65:sensor_device/DHT22.c ****             if (++timeout > 100) return 5;
  66:sensor_device/DHT22.c ****             DWT_Delay_us(1);
  67:sensor_device/DHT22.c ****         }
  68:sensor_device/DHT22.c ****     }
  69:sensor_device/DHT22.c **** 
  70:sensor_device/DHT22.c ****     // 校验和
  71:sensor_device/DHT22.c ****     uint8_t sum = data[0] + data[1] + data[2] + data[3];
  72:sensor_device/DHT22.c ****     if (sum != data[4]) return 6;
  73:sensor_device/DHT22.c **** 
  74:sensor_device/DHT22.c ****     // 数据转换
  75:sensor_device/DHT22.c ****     *humidity = ((data[0] << 8) | data[1]) / 10.0f;
  76:sensor_device/DHT22.c **** 
  77:sensor_device/DHT22.c ****     int16_t temp_raw = ((data[2] & 0x7F) << 8) | data[3];
  78:sensor_device/DHT22.c ****     *temperature = temp_raw / 10.0f;
  79:sensor_device/DHT22.c ****     if (data[2] & 0x80) *temperature = -*temperature;
  80:sensor_device/DHT22.c **** 
  81:sensor_device/DHT22.c ****     return 0;
  82:sensor_device/DHT22.c **** }
