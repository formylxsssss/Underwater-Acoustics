 572:ARM_SEGGER_RTT/SEGGER_RTT_printf.c **** 
 573:ARM_SEGGER_RTT/SEGGER_RTT_printf.c **** /*********************************************************************
 574:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *
 575:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *       SEGGER_RTT_printf
 576:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *
 577:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *  Function description
 578:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *    Stores a formatted string in SEGGER RTT control block.
 579:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *    This data is read by the host.
 580:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *
 581:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *  Parameters
 582:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *    BufferIndex  Index of "Up"-buffer to be used. (e.g. 0 for "Terminal")
 583:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *    sFormat      Pointer to format string, followed by the arguments for conversion
 584:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *
 585:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *  Return values
 586:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *    >= 0:  Number of bytes which have been stored in the "Up"-buffer.
 587:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *     < 0:  Error
 588:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *
 589:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *  Notes
 590:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *    (1) Conversion specifications have following syntax:
 591:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          %[flags][FieldWidth][.Precision]ConversionSpecifier
 592:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *    (2) Supported flags:
 593:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          -: Left justify within the field width
 594:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          +: Always print sign extension for signed conversions
 595:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          0: Pad with 0 instead of spaces. Ignored when using '-'-flag or precision
 596:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *        Supported conversion specifiers:
 597:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          c: Print the argument as one char
 598:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          d: Print the argument as a signed integer
 599:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          u: Print the argument as an unsigned integer
 600:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          x: Print the argument as an hexadecimal integer
 601:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          s: Print the string pointed to by the argument
 602:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  *          p: Print the argument as an 8-digit hexadecimal integer. (Argument shall be a pointer t
 603:ARM_SEGGER_RTT/SEGGER_RTT_printf.c ****  */
 604:ARM_SEGGER_RTT/SEGGER_RTT_printf.c **** int SEGGER_RTT_printf(unsigned BufferIndex, const char *sFormat, ...)
