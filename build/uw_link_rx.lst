  96:diff_signal/uw_link_rx.c **** static UW_ToneState_t UW_LinkRx_ReadTone(void)
  97:diff_signal/uw_link_rx.c **** {
  98:diff_signal/uw_link_rx.c ****     GPIO_PinState pc0 = HAL_GPIO_ReadPin(UW_LINK_BIT0_GPIO_PORT, UW_LINK_BIT0_GPIO_PIN);
  99:diff_signal/uw_link_rx.c ****     GPIO_PinState pc1 = HAL_GPIO_ReadPin(UW_LINK_BIT1_GPIO_PORT, UW_LINK_BIT1_GPIO_PIN);
 100:diff_signal/uw_link_rx.c **** 
 101:diff_signal/uw_link_rx.c ****     /* LM567: 匹配到频率时输出低电平 */
 102:diff_signal/uw_link_rx.c ****     bool bit0_active = (pc0 == GPIO_PIN_RESET);
 103:diff_signal/uw_link_rx.c ****     bool bit1_active = (pc1 == GPIO_PIN_RESET);
 104:diff_signal/uw_link_rx.c **** 
 105:diff_signal/uw_link_rx.c ****     if (bit0_active && (!bit1_active))
 106:diff_signal/uw_link_rx.c ****     {
 107:diff_signal/uw_link_rx.c ****         return UW_TONE_BIT0;
 108:diff_signal/uw_link_rx.c ****     }
 109:diff_signal/uw_link_rx.c ****     else if (bit1_active && (!bit0_active))
 110:diff_signal/uw_link_rx.c ****     {
 111:diff_signal/uw_link_rx.c ****         return UW_TONE_BIT1;
 112:diff_signal/uw_link_rx.c ****     }
 113:diff_signal/uw_link_rx.c ****     else if ((!bit0_active) && (!bit1_active))
 114:diff_signal/uw_link_rx.c ****     {
 115:diff_signal/uw_link_rx.c ****         return UW_TONE_NONE;
 116:diff_signal/uw_link_rx.c ****     }
 117:diff_signal/uw_link_rx.c ****     else
 118:diff_signal/uw_link_rx.c ****     {
 119:diff_signal/uw_link_rx.c ****         return UW_TONE_ERROR;
 120:diff_signal/uw_link_rx.c ****     }
 121:diff_signal/uw_link_rx.c **** }
